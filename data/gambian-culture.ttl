@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/gambia#> .

### Classes
ex:EthnicGroup a owl:Class ;
    rdfs:label "Ethnic Group"@en ;
    rdfs:comment "A group of people who share a common language, ancestry, culture, and traditions within The Gambia."@en .

ex:Religion a owl:Class ;
    rdfs:label "Religion"@en ;
    rdfs:comment "A system of beliefs, practices, and moral principles through which individuals worship and relate to a higher spiritual power."@en .

ex:Food a owl:Class ;
    rdfs:label "Food"@en ;
    rdfs:comment "A substance consumed by humans to provide nutritional support and energy. In cultural contexts, food preparation and composition may vary according to traditions, culture, and religious practices."@en .

ex:Region a owl:Class ;
    rdfs:label "Region"@en ;
    rdfs:comment "A defined geographical or administrative area within a country, used to represent spatial divisions such as provinces, districts, or local territories."@en .

ex:Tradition a owl:Class ;
    rdfs:label "Tradition"@en ;
    rdfs:comment "A long-standing custom, belief, or practice that is transmitted from one generation to another within a family, community, or cultural group."@en .

ex:Music a owl:Class ;
    rdfs:label "Music"@en ;
    rdfs:comment "The art of organizing vocal, instrumental, or other sounds in time to create a deliberate and often aesthetic form of expression."@en .

ex:Ingredient a owl:Class ;
    rdfs:label "Ingredient"@en ;
    rdfs:comment "A substance or component used in the preparation of a food item or dish, such as meat, vegetables, grains, spices, or other edible materials."@en .

ex:Festival a owl:Class ;
    rdfs:label "Festival"@en ;
    rdfs:comment "An organised and often recurring community celebration associated with cultural, religious, artistic, or traditional themes, typically involving collective participation and social interaction."@en .

### Object Properties and property semantics

ex:hasFood a owl:ObjectProperty;
           rdfs:label "has food"@en ;
           rdfs:comment "Relates an ethinic group to a food that is commonly associated with or tradionally consumed by that group."@en ;
           rdfs:domain ex:EthnicGroup ;
           rdfs:range ex:Food .
           
ex:isMostlyEatenBy a owl:ObjectProperty ;
                   rdfs:label "is mostly eaten by"@en ;
                   rdfs:comment "Relates a food to an ethnic group that commonly or traditionally consumes it."@en ;
                   rdfs:domain ex:Food ;
                   rdfs:range ex:EthincGroup ;
                   owl:inverseOf ex:hasFood .
ex:locatedIn a owl:ObjectProperty ;
             rdfs:domain ex:EthnicGroup ;
             rdfs:label "located in"@en ;
             rdfs:comment "Relates an ethnic group to a region where it is commonly found, historically settled or culturally associated."@en ;
             rdfs:domain ex:EthinicGroup ;
             rdfs:range ex:Region .

ex:isMostlyEatenBy a owl:ObjectProperty ;
                   rdfs:label "is mostly eaten by"@en
                   rdfs:comment "whatever the definiton is"@en ;
                   rdfs:domain ex:Food ;
                   rdfs:range ex:EthnicGroup .

ex:hasIngredient a owl:ObjectProperty ;
                 rdfs:label "has ingredient"@en
                 rdfs:comment "Relates a food item to an ingredeint used in its preparation."@en ;
                 rdfs:domain ex:Food ;
                 rdfs:range ex:Ingredient .

ex:forbidsIngredient a owl:ObjectProperty ;
                     rdfs:label "forbids ingredient"@en ;
                     rdfs:comment "It relates a religion to an ingredient that is prohibited or traditionlly avoided within its dietary practices."@en ;
                     rdfs:domain ex:Religion ;
                     rdfs:range ex:Ingredient .

ex:practicesReligion a owl:ObjectProperty ;
                     rdfs:label "practices religion"@en ;
                     rdfs:comment "Relates ethnic group to a religion that is commonly practiced or historically associated with that group."@en ;
                     rdfs:domain ex:EthnicGroup ;
                     rdfs:range ex:Religion .
                     
ex:hasTradition a owl:ObjectProperty ;
                rdfs:label "has tradition"@en ;
                rdfs:comment "Relates an ethnic group to a tradition that is commonly practiced, inherited or culturally assoicated with that group"@en ;
                rdfs:domain ex:EthnicGroup ;
                rdfs:range ex:Tradition .
                
ex:hasMusic a owl:ObjectProperty ;
            rdfs:label "has music"@en ;
            rdfs:comment "Relates en ethnic group to a form of music that is traditionally practiced, performed or culturally associated with that group"@en ;
            rdfs:domain ex:EthinicGroup ;
            rdfs:range ex:Music .
            
### Instances of Ethnic Groups
ex:Mandinkas a ex:EthnicGroup .
ex:Wollofs a ex:EthnicGroup .
ex:Fulas a ex:EthnicGroup .
ex:Jolas a ex:EthnicGroup .
ex:Akus a ex:EthnicGroup .
ex:Sereres a ex:EthnicGroup .
ex:Manjagoes a ex:EthnicGroup .

### Instances of Religions
ex:Christianity a ex:Religion .
ex:Islam a ex:Religion .
ex:TraditionalReligion a ex:Religion .

### Instances of Foods
ex:Domada a ex:Food .
ex:Yassa a ex:Food .
ex:CestBon a ex:Food .
ex:SuperKanja a ex:Food .
ex:Stew a ex:Food .
ex:Benechin a ex:Food .
ex:Nanburru a ex:Food .
ex:Afra a ex:Food .
ex:Chakery a ex:Food .
ex:Futi a ex:Food .

### Instances of Regions
ex:Banjul a ex:Region .
ex:Foni a ex:Region .

### Relationships Between Ethnic Groups and Foods
ex:Mandinkas ex:hasFood ex:Domada .
ex:Wollofs ex:hasFood ex:Benechin .
ex:Fulas ex:hasFood ex:Futi .

ex:Yassa ex:isMostlyEatenBy ex:Mandinkas,
    ex:Sereres,
    ex:Fulas,
    ex:Jolas,
    ex:Akus,
    ex:Manjagoes .

### Instances of Ingredients
ex:Pork a ex:Ingredient .
ex:Beef a ex:Ingredient .
ex:Vegetables a ex:Ingredient .
ex:Chicken a ex:Ingredient .

### Religious Food Restriction
ex:Islam ex:forbidsIngredient ex:Pork .

### Linking Ethnic Groups to Religions
ex:Jolas ex:practicesReligion ex:Christianity,
    ex:Islam .

ex:Fulas ex:practicesReligion ex:Islam .
ex:Wollofs ex:practicesReligion ex:Islam .
ex:Mandinkas ex:practicesReligion ex:Islam .

### Advanced OWL Restriction
ex:PorkDish a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Food
            [ a owl:Restriction ;
              owl:onProperty ex:hasIngredient ;
              owl:hasValue ex:Pork
            ]
        )
    ] .
