@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/gambia#> .

### Classes
ex:EthnicGroup a owl:Class ;
                 rdfs:label "Ethnic group"@en ;
                 rdfs:comment "A group of individuals who speak common language, ancestry culture and traditions within the Gambia."@en.
ex:Religion a owl:Class ;
              rdfs:label "Religion"@en ;
              rdfs:comment "Religion is a system of beliefs, practices and moral principles through which people worship and relate to higher spiritual power."@en .
              
ex:Food a owl:Class ;
          rdfs:label"Food"@en ;
          rdfs:comment "Food is a substance consumed by humans to provide nutritional support and energy. In cultureal contexts , food preparation and  composition may varie according to traditions , culture , religion practices"@en .
        
ex:Region a owl:Class ;
            rdfs:label "Region"@en ;
            rdfs:comment "Region is a defined  geographical or administrative area within a country used to represent spatial devisions such as provinces districts or local terrotories."@en . 
 
ex:Tradition a owl:Class .
ex:Music a owl:Class .
ex:Ingredient a owl:Class .
ex:Festival a owl:Class .

### Object Properties
ex:hasFood a owl:ObjectProperty .
ex:occupantsOf a owl:ObjectProperty .
ex:practicedBy a owl:ObjectProperty .
ex:locatedIn a owl:ObjectProperty .
ex:knownBy a owl:ObjectProperty .
ex:belongsTo a owl:ObjectProperty .
ex:isMostlyEatenBy a owl:ObjectProperty .
ex:hasIngredient a owl:ObjectProperty.
ex:forbidsIngredient a owl:ObjectProperty .
ex:practicesReligion a owl:ObjectProperty .

##property semantics

ex:hasFood rdfs:domain ex:EthnicGroup;
           rdfs:range ex:Food .
           
ex:locatedIn rdfs:domain ex:EthnicGroup;
            rdfs:range ex:Region .
            
ex:isMostlyEatenBy rdfs:domain ex:Food;
                   rdfs:range ex:EthnicGroup .
ex:hasIngredient rdfs:domain ex:Food;
                 rdfs:range ex:Ingredient.
ex:forbidsIngredient rdfs:domain ex:Religion;
                     rdfs:range ex:Ingredient.
ex:practicesReligion rdfs:domain ex:EthnicGroup;
                     rdfs:range ex:Religion .
                     
                     
###Instances of ethinicities
ex:Mandinkas a ex:EthnicGroup .
ex:Wollofs a ex:EthnicGroup .
ex:Fulas a ex:EthnicGroup .
ex:Jolas a ex:EthnicGroup .
ex:Akus  a ex:EthnicGroup.
ex:Sereres a ex:EthnicGroup .
ex:Manjagoes a ex:EthnicGroup .



#Instances  of Religions
ex:Christianity a ex:Religion .
ex:Islam a ex:Religion .
ex:TraditionalReligion a ex:Religion .

#Instances of foods
ex:Domada a ex:Food .
ex:Yassa a ex:Food .
ex:CestBon a ex:Food.
ex:SuperKanja a ex:Food .
ex:Stew a ex:Food .
ex:Benechin a ex:Food .
ex:Nanburru a ex:Food .
ex:Afra a ex:Food .
ex:Chakery a ex:Food .
ex:Futi a ex:Food .

#Instances of places
ex:Banjul a ex:Region .
ex:Foni a ex:Region .

#Link of relationship between ethinicities and food.
ex:Mandinkas ex:hasFood ex:Domada .
ex:Wollofs ex:hasFood ex:Benechin .
ex:Fulas ex:hasFood ex:Futi.
ex:Yassa ex:isMostlyEatenBy ex:Mandinkas,
                    ex:Sereres,
                    ex:Fulas,
                    ex:Jolas,
                    ex:Akus,
                    ex:Manjagoes.
                    
                    
#Instances of ingredient class

ex:Pork a ex:Ingredient .
ex:Beef a ex:Ingredient .
ex:Vegetables a ex:Ingredient .
ex:Chicken a ex:Ingredient .

#Restritions

ex:Islam ex:forbidsIngredient ex:Pork .

#Linking Ethinic Groups to Religion

ex:Jolas ex:practicesReligion ex:Christianity,
                             ex:Islam .
                             
ex:Fulas ex:practicesReligion ex:Islam .
ex:Wolofs ex:practicesReligion ex:Islam .
ex:Mandinkas ex:practicesReligion ex:Islam .

# Addition of advanced restriction

ex:PorkDish a owl:Class;
              owl:equivalentClass [
            a owl:Class;
              owl:intersectionOf (
                   ex:Food
                   [ a owl:Restriction ;
                    owl:onProperty ex:hasIngredient ;
                    owl:hasValue ex:Pork ]
)
] .
